# Copiá este archivo como `.env` (en esta misma carpeta) SOLO en el servidor.
# Lo lee docker compose. Todas las variables son opcionales: si no ponés
# ninguna, los defaults del docker-compose.yml alcanzan para probar.
#
# Ojo: este .env es para Docker. La clave de Gemini va en `backend/.env`.

# Dónde viven tus datos en el servidor. Fuera del repo a propósito.
GP_DATA_DIR=/srv/gamerprofile/database

# Puerto en el que vas a entrar desde la LAN: http://<ip-del-server>:8080
GP_PORT=8080

# Dueño de los archivos que escribe el contenedor. Tienen que ser la salida de
# `id -u` y `id -g` de tu usuario, o la base te va a quedar como root.
GP_UID=1000
GP_GID=1000
