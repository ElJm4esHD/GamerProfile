{
  "extends": "../tsconfig.base.json",
  "compilerOptions": {
    "lib": ["ES2022"],
    "types": ["node"],
    // rootDir en la raíz del repo para que `shared` se emita al lado de
    // `backend`, con la misma estructura que tiene el proyecto. Eso importa:
    // db/paths.ts calcula ROOT_DIR subiendo tres niveles desde su ubicación,
    // así que el JS compilado tiene que conservar esa jerarquía.
    "rootDir": "..",
    "outDir": "../build",
    "sourceMap": true
  },
  "include": ["src/**/*", "../shared/src/**/*"]
}
